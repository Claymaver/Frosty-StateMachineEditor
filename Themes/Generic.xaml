<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:StateMachineEditorPlugin"
    xmlns:core="clr-namespace:Frosty.Core.Controls;assembly=FrostyCore">

    <!-- ── Expander arrow button ───────────────────────────────────────── -->
    <Style x:Key="TreeExpanderStyle" TargetType="{x:Type ToggleButton}">
        <Setter Property="Focusable"    Value="False"/>
        <Setter Property="Width"        Value="16"/>
        <Setter Property="Height"       Value="16"/>
        <Setter Property="Background"   Value="Transparent"/>
        <Setter Property="BorderBrush"  Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border Background="Transparent" Width="16" Height="16">
                        <Path x:Name="Arrow"
                              Data="M 4 6 L 8 10 L 12 6"
                              Stroke="#FFF8F8F8" StrokeThickness="1.8"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Arrow" Property="Data" Value="M 4 10 L 8 6 L 12 10"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Arrow" Property="Stroke" Value="#FFFFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── TreeViewItem ────────────────────────────────────────────────── -->
    <Style x:Key="DarkTreeViewItemStyle" TargetType="{x:Type TreeViewItem}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#FFF8F8F8"/>
        <Setter Property="Padding"    Value="2,2,2,2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TreeViewItem}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ToggleButton x:Name="Expander" Grid.Column="0"
                                              ClickMode="Press"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                              Style="{StaticResource TreeExpanderStyle}"/>
                                <ContentPresenter x:Name="PART_Header" Grid.Column="1"
                                                  ContentSource="Header"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ItemsPresenter x:Name="ItemsHost" Grid.Row="1" Margin="16,0,0,0"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded"  Value="false"><Setter TargetName="ItemsHost" Property="Visibility"  Value="Collapsed"/></Trigger>
                        <Trigger Property="HasItems"    Value="false"><Setter TargetName="Expander"  Property="Visibility"  Value="Hidden"/></Trigger>
                        <Trigger Property="IsSelected"  Value="true"> <Setter TargetName="Bd"        Property="Background"  Value="#FF404040"/></Trigger>
                        <Trigger Property="IsMouseOver" Value="true"> <Setter TargetName="Bd"        Property="Background"  Value="#FF303030"/></Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── TabItem: bottom-border underline on selection ───────────────── -->
    <Style x:Key="DarkTabItemStyle" TargetType="{x:Type TabItem}">
        <Setter Property="Padding"  Value="10,5"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabItem}">
                    <Grid>
                        <Border x:Name="TabBd" Background="Transparent"
                                BorderThickness="0" Padding="{TemplateBinding Padding}">
                            <TextBlock x:Name="TabTxt" Text="{TemplateBinding Header}"
                                       Foreground="#FF868686"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border x:Name="Underline" Height="2" VerticalAlignment="Bottom"
                                Background="Transparent" Margin="4,0,4,0"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="TabBd"     Property="Background"  Value="#FF292929"/>
                            <Setter TargetName="TabTxt"    Property="Foreground"  Value="#FFF8F8F8"/>
                            <Setter TargetName="Underline" Property="Background"  Value="#FF6C6C6C"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="TabBd"  Property="Background" Value="#FF303030"/>
                            <Setter TargetName="TabTxt" Property="Foreground" Value="#FFF8F8F8"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Main editor ─────────────────────────────────────────────────── -->
    <Style TargetType="{x:Type local:StateMachineEditor}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:StateMachineEditor}">
                    <Grid Background="#FF141414">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300" MinWidth="180" MaxWidth="500"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT: Explorer -->
                        <Border Background="#FF292929" BorderBrush="#FF3F3F3F" BorderThickness="0,0,1,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="#FF303030"
                                        BorderBrush="#FF3F3F3F" BorderThickness="0,0,0,1">
                                    <DockPanel>
                                        <Button x:Name="PART_ViewToggle" DockPanel.Dock="Right"
                                                        Content="Graph" Width="74" Height="20"
                                                Margin="4,0,6,0" FontSize="10"
                                                Background="#FF454545" Foreground="#FFF8F8F8"
                                                BorderBrush="#FF3F3F3F" BorderThickness="1"
                                                ToolTip="Switch between Graph and EBX Property views"/>
                                        <Button x:Name="PART_PreviewsBtn" DockPanel.Dock="Right"
                                                Content="Previews" Width="64" Height="20"
                                                Margin="0,0,0,0" FontSize="10"
                                                Background="#FF454545" Foreground="#FFF8F8F8"
                                                BorderBrush="#FF3F3F3F" BorderThickness="1"
                                                ToolTip="Open Animation Preview Browser"/>
                                        <TextBlock Text="EXPLORER" Foreground="#FF868686"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                                    </DockPanel>
                                </Border>

                                <Border Grid.Row="1" Padding="6,4" Background="#FF292929"
                                        BorderBrush="#FF3F3F3F" BorderThickness="0,0,0,1">
                                    <TextBox x:Name="PART_SearchBox"
                                             Background="#FF292929" Foreground="#FFF8F8F8"
                                             CaretBrush="#FFF8F8F8" BorderBrush="#FF3F3F3F"
                                             BorderThickness="1" Padding="6,3" FontSize="11"
                                             Height="22" VerticalContentAlignment="Center"/>
                                </Border>

                                <Border Grid.Row="2" Padding="6,3" Background="#FF292929"
                                        BorderBrush="#FF3F3F3F" BorderThickness="0,0,0,1">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Sort" Foreground="#FF868686" FontSize="10"
                                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <ComboBox x:Name="PART_SortCombo" Width="160" Height="22" FontSize="11">
                                            <ComboBoxItem Content="Category then Name" IsSelected="True"/>
                                            <ComboBoxItem Content="Name A-Z"/>
                                            <ComboBoxItem Content="Name Z-A"/>
                                            <ComboBoxItem Content="None"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Border>

                                <TreeView x:Name="PART_TreeView" Grid.Row="3"
                                          Background="Transparent" BorderThickness="0"
                                          Foreground="#FFF8F8F8"
                                          ItemContainerStyle="{StaticResource DarkTreeViewItemStyle}"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling"/>
                            </Grid>
                        </Border>

                        <GridSplitter Grid.Column="1" Width="4" Background="#FF3F3F3F"
                                      HorizontalAlignment="Stretch"/>

                        <!-- RIGHT: Graph + Inspector / Property Grid -->
                        <Grid Grid.Column="2">
                            <!-- Property Grid view (default) -->
                            <core:FrostyPropertyGrid x:Name="PART_PropertyGrid"/>

                            <!-- Graph view (toggled via button) -->
                            <Grid x:Name="PART_GraphView" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="4"/>
                                <RowDefinition Height="220" MinHeight="80" MaxHeight="420"/>
                            </Grid.RowDefinitions>

                            <!-- Infinite grid canvas -->
                            <Border x:Name="PART_CanvasBorder" ClipToBounds="True"
                                    BorderBrush="#FF3F3F3F" BorderThickness="0">
                                <Border.Background>
                                    <DrawingBrush TileMode="Tile" Viewport="0,0,50,50" ViewportUnits="Absolute">
                                        <DrawingBrush.Drawing>
                                            <GeometryDrawing Brush="#FF141414">
                                                <GeometryDrawing.Pen>
                                                    <Pen Brush="#FF232323" Thickness="1"/>
                                                </GeometryDrawing.Pen>
                                                <GeometryDrawing.Geometry>
                                                    <GeometryGroup>
                                                        <LineGeometry StartPoint="0,0" EndPoint="50,0"/>
                                                        <LineGeometry StartPoint="0,0" EndPoint="0,50"/>
                                                    </GeometryGroup>
                                                </GeometryDrawing.Geometry>
                                            </GeometryDrawing>
                                        </DrawingBrush.Drawing>
                                    </DrawingBrush>
                                </Border.Background>
                                <Canvas x:Name="PART_Canvas" Width="100000" Height="100000"
                                        Background="Transparent"
                                        HorizontalAlignment="Left" VerticalAlignment="Top"/>
                            </Border>

                            <GridSplitter Grid.Row="1" Height="4" Background="#FF3F3F3F"
                                          HorizontalAlignment="Stretch" VerticalAlignment="Center"/>

                            <!-- Node Inspector -->
                            <Border Grid.Row="2" Background="#FF292929"
                                    BorderBrush="#FF3F3F3F" BorderThickness="0,1,0,0">
                                <TabControl x:Name="PART_EditPanel"
                                            Background="#FF292929" BorderBrush="#FF3F3F3F"
                                            BorderThickness="0" Foreground="#FFF8F8F8"
                                            ItemContainerStyle="{StaticResource DarkTabItemStyle}">
                                    <TabItem Header="Overview">
                                        <TextBlock Text="Select a node in the graph to inspect it."
                                                   Foreground="#FF868686" FontStyle="Italic"
                                                   FontSize="11" VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                    </TabItem>
                                </TabControl>
                            </Border>
                        </Grid> <!-- /PART_GraphView -->
                        </Grid> <!-- /right column -->
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
